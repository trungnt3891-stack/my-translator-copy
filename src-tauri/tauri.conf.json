{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProSports interpreter",
  "version": "1.0.0",
  "identifier": "com.prosports.interpreter",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "ProSports interpreter",
        "width": 1000,
        "height": 600,
        "minWidth": 820,
        "minHeight": 400,
        "center": true,
        "transparent": false,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": true,
        "skipTaskbar": false
      }
    ]
  }
}